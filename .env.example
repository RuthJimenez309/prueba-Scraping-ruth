# ---------------------------------------------------------------------------
# newsscraper configuration (all values are optional; sane defaults apply)
# Copy to ".env" and adjust. Docker Compose reads this file automatically.
# ---------------------------------------------------------------------------

# Browser identity sent to the sites. Use a realistic desktop User-Agent.
NEWSSCRAPER_USER_AGENT="Mozilla/5.0 (X11; Linux x86_64) AppleWebKit/537.36 (KHTML, like Gecko) Chrome/120.0.0.0 Safari/537.36"

# Run the browser headless (true) or headed (false). Keep true in Docker.
NEWSSCRAPER_HEADLESS=true

# Max number of article pages fetched concurrently.
NEWSSCRAPER_CONCURRENCY=4

# Polite base delay (seconds) applied before each article fetch, plus random jitter.
NEWSSCRAPER_DELAY=1.0
NEWSSCRAPER_JITTER=0.5

# Per-page navigation timeout in milliseconds.
NEWSSCRAPER_NAV_TIMEOUT_MS=30000

# Hard cap on how many matched articles to fetch in a single run.
NEWSSCRAPER_MAX_ARTICLES=40

# Safety cap on how many sitemap entries to scan while searching.
NEWSSCRAPER_MAX_SITEMAP_ENTRIES=4000

# Also crawl deep archive sitemaps (slower, broader history). true/false.
NEWSSCRAPER_INCLUDE_ARCHIVE=false

# Where CSV + SQLite outputs are written.
NEWSSCRAPER_OUTPUT_DIR=data

# Preferred content language hint.
NEWSSCRAPER_LOCALE=es-HN

# Logging level: DEBUG, INFO, WARNING, ERROR.
NEWSSCRAPER_LOG_LEVEL=INFO
